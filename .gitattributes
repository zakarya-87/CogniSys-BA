# Normalize all text files to LF in the repository
* text=auto eol=lf

# Explicitly LF for files that must never be CRLF
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
*.woff binary
