# .env.example — copy to .env.local and fill in your values
# ⚠️  Never commit .env.local — it is gitignored (covered by *.local)

# ── Logging ───────────────────────────────────────────────────────────────────
# pino log level: trace | debug | info | warn | error | fatal
# Defaults to 'debug' in development, 'info' in production
LOG_LEVEL=

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Prefix: FEATURE_FLAG_<UPPERCASE_FLAG_NAME>=true|false
# All flags default to 'true' except otel_tracing (requires OTLP endpoint).
# Override here to disable a feature in a specific environment.
# FEATURE_FLAG_AI_STREAMING=true
# FEATURE_FLAG_VECTOR_MEMORY=true
# FEATURE_FLAG_GITHUB_API=true
# FEATURE_FLAG_GOOGLE_AUTH=true
# FEATURE_FLAG_OTEL_TRACING=false
# FEATURE_FLAG_PREDICTIVE_CORE=true
# FEATURE_FLAG_WAR_ROOM=true
# FEATURE_FLAG_CONSTRUCT_VIEW=true

# ── AI Providers ──────────────────────────────────────────────────────────────
# SECURITY: GEMINI_API_KEY is SERVER-ONLY. It is NEVER injected into the client
# bundle. All Gemini calls are proxied through POST /api/gemini/generate.
GEMINI_API_KEY=

# Mistral API Key — server-side only (proxied via /api/mistral/chat)
MISTRAL_API_KEY=

# ── Azure OpenAI (optional fallback) ──────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=

# ── Firebase (Server-side Admin SDK) ──────────────────────────────────────────
# Required for: verifying Firebase ID tokens (POST /api/auth/firebase-session),
# Firestore access, and vector memory service.
#
# How to get it:
#   Firebase Console → Project Settings → Service Accounts → Generate new private key
#   Paste the entire JSON as a single-line string (or use Cloud Run Secret Manager).
FIREBASE_SERVICE_ACCOUNT=

# ── Firebase Auth (Client-side — GitHub & Google providers) ───────────────────
# These are PUBLIC values (Vite VITE_ prefix = injected into browser bundle).
# Firebase config is already in firebase-applet-config.json for the primary app.
# Only needed if you want to override the JSON config via env vars:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
#
# Firebase Console setup required:
#   Authentication → Sign-in method → Enable "GitHub" and "Google" providers
#   GitHub: add Client ID + Secret from github.com/settings/developers
#   Authorized domains: add your Cloud Run / custom domain

# ── GitHub OAuth App (Legacy — kept for backward compat, not used by default) ──
# The primary auth flow now uses Firebase Auth (signInWithPopup with GithubAuthProvider).
# These are only needed if you re-enable the legacy /auth/callback server route.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
# Set OTEL_ENABLED=true and provide an OTLP endpoint for production tracing.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cognisys-ba
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
