# .env.example — copy to .env.local and fill in your values
# ⚠️  Never commit .env.local — it is gitignored (covered by *.local)

# ── Logging ───────────────────────────────────────────────────────────────────
# pino log level: trace | debug | info | warn | error | fatal
# Defaults to 'debug' in development, 'info' in production
LOG_LEVEL=

# ── AI Providers ──────────────────────────────────────────────────────────────
# SECURITY: GEMINI_API_KEY is SERVER-ONLY. It is NEVER injected into the client
# bundle. All Gemini calls are proxied through POST /api/gemini/generate.
GEMINI_API_KEY=

# Mistral API Key — server-side only (proxied via /api/mistral/chat)
MISTRAL_API_KEY=

# ── Azure OpenAI (optional fallback) ──────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=

# ── GitHub OAuth App ───────────────────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
# Callback URL: <App URL>/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OpenTelemetry Tracing ──────────────────────────────────────────────────────
# Service name shown in traces (default: cognisys-ba)
OTEL_SERVICE_NAME=cognisys-ba
# OTLP/HTTP endpoint for trace export (default: http://localhost:4318)
# For GCP: use https://telemetry.googleapis.com/v1/traces (Cloud Trace OTLP endpoint)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Set to 'false' to disable tracing entirely (e.g. in local dev without a collector)
OTEL_ENABLED=false
