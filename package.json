{
  "name": "cognisys-ba---the-catalyst-hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:functions": "esbuild functions/src/index.ts --bundle --platform=node --target=node20 --outfile=functions/lib/index.js --external:firebase-admin --external:firebase-functions --external:@grpc/grpc-js --external:@grpc/proto-loader",
    "build:all": "npm run build && npm run build:functions",
    "deploy:firebase": "npm run build:all && npx firebase deploy --token \"$FIREBASE_TOKEN\"",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "docker:build": "docker build -t cognisys-ba:local .",
    "docker:run": "docker run --env-file .env.local -p 8080:8080 cognisys-ba:local",
    "docker:dev": "docker-compose --profile dev up app-dev",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "db:seed:clear": "dotenv -e .env.local -- tsx scripts/seed.ts --clear"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@heroicons/react": "^2.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tensorflow/tfjs": "^4.22.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "axios": "^1.14.0",
    "chart.js": "^4.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.3",
    "helmet": "^8.1.0",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.4",
    "idb": "^8.0.3",
    "json5": "^2.2.3",
    "jsonrepair": "^3.13.3",
    "lucide-react": "^1.7.0",
    "mathjs": "15.1.1",
    "mermaid": "^11.14.0",
    "motion": "^12.38.0",
    "nodemailer": "^8.0.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "stripe": "^22.0.0",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^4.2.2",
    "typescript-json-schema": "^0.67.1",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.7",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.3"
  }
}
